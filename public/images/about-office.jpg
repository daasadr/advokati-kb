<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e2d3e"/>
      <stop offset="100%" style="stop-color:#0f1923"/>
    </linearGradient>
    <linearGradient id="light" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#c9a84c;stop-opacity:0.15"/>
      <stop offset="100%" style="stop-color:#c9a84c;stop-opacity:0"/>
    </linearGradient>
  </defs>
  <rect width="800" height="600" fill="url(#bg)"/>
  <!-- Window/light source -->
  <rect x="60" y="40" width="200" height="280" fill="url(#light)" rx="2"/>
  <rect x="60" y="40" width="200" height="280" fill="none" stroke="#c9a84c" stroke-width="1" opacity="0.2" rx="2"/>
  <!-- Bookshelf -->
  <rect x="540" y="80" width="220" height="440" fill="#162030"/>
  <rect x="540" y="80" width="220" height="440" fill="none" stroke="#c9a84c" stroke-width="0.5" opacity="0.2"/>
  <!-- Books rows -->
  <rect x="555" y="100" width="18" height="80" fill="#c9a84c" opacity="0.6"/>
  <rect x="576" y="110" width="14" height="70" fill="#8a9bb0" opacity="0.5"/>
  <rect x="593" y="105" width="20" height="75" fill="#e8e0d0" opacity="0.3"/>
  <rect x="616" y="115" width="16" height="65" fill="#c9a84c" opacity="0.4"/>
  <rect x="635" y="100" width="22" height="80" fill="#8a9bb0" opacity="0.4"/>
  <rect x="660" y="108" width="15" height="72" fill="#e8e0d0" opacity="0.2"/>
  <rect x="678" y="100" width="18" height="80" fill="#c9a84c" opacity="0.5"/>
  <rect x="700" y="112" width="14" height="68" fill="#8a9bb0" opacity="0.3"/>
  <line x1="555" y1="182" x2="720" y2="182" stroke="#c9a84c" stroke-width="0.5" opacity="0.2"/>
  <!-- Second row -->
  <rect x="555" y="195" width="20" height="85" fill="#8a9bb0" opacity="0.4"/>
  <rect x="578" y="200" width="16" height="80" fill="#c9a84c" opacity="0.5"/>
  <rect x="597" y="192" width="24" height="88" fill="#e8e0d0" opacity="0.25"/>
  <rect x="624" y="200" width="18" height="80" fill="#c9a84c" opacity="0.35"/>
  <rect x="645" y="195" width="14" height="85" fill="#8a9bb0" opacity="0.4"/>
  <rect x="662" y="202" width="20" height="78" fill="#e8e0d0" opacity="0.2"/>
  <rect x="685" y="195" width="16" height="85" fill="#c9a84c" opacity="0.45"/>
  <line x1="555" y1="285" x2="720" y2="285" stroke="#c9a84c" stroke-width="0.5" opacity="0.2"/>
  <!-- Desk -->
  <rect x="80" y="400" width="420" height="12" fill="#1a2a3a" rx="1"/>
  <rect x="90" y="412" width="8" height="120" fill="#162030"/>
  <rect x="480" y="412" width="8" height="120" fill="#162030"/>
  <!-- Lamp on desk -->
  <circle cx="380" cy="380" r="30" fill="#c9a84c" opacity="0.08"/>
  <rect x="375" y="375" width="3" height="26" fill="#c9a84c" opacity="0.4"/>
  <ellipse cx="376" cy="360" rx="25" ry="8" fill="#c9a84c" opacity="0.3"/>
  <!-- Chair silhouette -->
  <rect x="220" y="370" width="80" height="36" fill="#1a2530" rx="3"/>
  <rect x="200" y="350" width="120" height="30" fill="#1e2d3e" rx="3"/>
  <!-- Gold accent line at bottom -->
  <line x1="0" y1="590" x2="800" y2="590" stroke="#c9a84c" stroke-width="1" opacity="0.3"/>
</svg>
