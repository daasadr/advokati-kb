<svg xmlns="http://www.w3.org/2000/svg" width="1920" height="1080" viewBox="0 0 1920 1080">
  <defs>
    <linearGradient id="a" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a1018;stop-opacity:1"/>
      <stop offset="50%" style="stop-color:#1a2a3a;stop-opacity:1"/>
      <stop offset="100%" style="stop-color:#0f1923;stop-opacity:1"/>
    </linearGradient>
    <linearGradient id="b" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#c9a84c;stop-opacity:0.08"/>
      <stop offset="100%" style="stop-color:#c9a84c;stop-opacity:0"/>
    </linearGradient>
  </defs>
  <rect width="1920" height="1080" fill="url(#a)"/>
  <rect width="1920" height="1080" fill="url(#b)"/>
  <!-- Architectural lines suggesting courthouse columns -->
  <line x1="300" y1="0" x2="300" y2="1080" stroke="#c9a84c" stroke-width="0.5" opacity="0.12"/>
  <line x1="600" y1="0" x2="600" y2="1080" stroke="#c9a84c" stroke-width="0.5" opacity="0.08"/>
  <line x1="900" y1="0" x2="900" y2="1080" stroke="#c9a84c" stroke-width="0.5" opacity="0.06"/>
  <line x1="1200" y1="0" x2="1200" y2="1080" stroke="#c9a84c" stroke-width="0.5" opacity="0.08"/>
  <line x1="1500" y1="0" x2="1500" y2="1080" stroke="#c9a84c" stroke-width="0.5" opacity="0.12"/>
  <line x1="1800" y1="0" x2="1800" y2="1080" stroke="#c9a84c" stroke-width="0.5" opacity="0.05"/>
  <!-- Horizontal lines -->
  <line x1="0" y1="270" x2="1920" y2="270" stroke="#c9a84c" stroke-width="0.3" opacity="0.06"/>
  <line x1="0" y1="540" x2="1920" y2="540" stroke="#c9a84c" stroke-width="0.3" opacity="0.06"/>
  <line x1="0" y1="810" x2="1920" y2="810" stroke="#c9a84c" stroke-width="0.3" opacity="0.06"/>
</svg>
